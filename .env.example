# === docker-claw Configuration ===

# SSH port exposed on host
SSH_PORT=2222

# SSH public key(s) for the openclaw user (paste your public key here)
SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAA... your-comment

# Read-write volume: OpenClaw config directory (persisted on host)
RW_OPENCLAW_CONFIG=./data/openclaw-config

# Read-only volume: shared directory from host (mounted at /mnt/shared)
RO_VOLUME_1=./data/readonly

# SSH host keys (persist across rebuilds)
RW_SSH_HOST_KEYS=./data/ssh-host-keys
